{
  "name": "chaye-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-entrypoints.mjs",
    "dev:frontend": "vite",
    "dev:docker": "docker compose up --build frontend-dev",
    "dev:e2e-stack": "node scripts/compose-e2e.mjs up",
    "build": "tsc -b && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "docs:diagrams": "node scripts/generate-doc-diagrams.mjs",
    "e2e": "playwright test",
    "e2e:stack": "node scripts/compose-e2e.mjs test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install chromium",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test && pnpm run coverage && pnpm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "axios": "^1.18.1",
    "barcode-detector": "^3.2.0",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^6.30.1",
    "styled-components": "^6.1.12",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "typescript": "^5.2.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "ajv": "^6.14.0",
      "cross-spawn": "^7.0.6",
      "flatted": "^3.4.2",
      "js-yaml": "^4.2.0",
      "micromatch": "^4.0.8",
      "minimatch": "^9.0.6",
      "nanoid": "^3.3.11",
      "picomatch": "^4.0.3",
      "postcss": "^8.5.10",
      "rollup": "^4.59.0"
    }
  },
  "packageManager": "pnpm@9.6.0"
}
